<Window
    x:Class="DevCoreHospital.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:DevCoreHospital.Views"
    xmlns:doctorViews="using:DevCoreHospital.Views.Doctor"
    Title="DevCore Hospital">

    <NavigationView x:Name="AppNavigationView"
                    IsBackButtonVisible="Collapsed"
                    PaneDisplayMode="Left"
                    SelectionChanged="AppNavigationView_SelectionChanged">

        <NavigationView.MenuItems>
            <NavigationViewItem Content="Medical Evaluation" Tag="MedicalEvaluation" Icon="Document"/>
            <NavigationViewItem Content="Doctor Schedule" Tag="DoctorSchedule" Icon="Calendar"/>
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame"/>
    </NavigationView>
</Window>