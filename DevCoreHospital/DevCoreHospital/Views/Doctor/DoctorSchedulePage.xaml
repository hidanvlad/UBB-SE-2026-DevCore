<Page
    x:Class="DevCoreHospital.Views.Doctor.DoctorSchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:DevCoreHospital.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Doctor Schedule"
                       FontSize="52"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1" Content="Previous" Margin="8,0,0,0" Command="{Binding PreviousDayCommand}"/>
            <Button Grid.Column="2" Content="Today" Margin="8,0,0,0" Command="{Binding TodayCommand}"/>
            <Button Grid.Column="3" Content="Next" Margin="8,0,0,0" Command="{Binding NextDayCommand}"/>

            <TextBlock Grid.Column="4"
                       Text="{Binding SelectedDateText}"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="18"/>

            <Button Grid.Column="5" Content="Refresh" Margin="20,0,0,0" Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- Error -->
        <Border Grid.Row="1"
                Background="#FFF7ED"
                BorderBrush="#F59E0B"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,10"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#9A3412" TextWrapping="Wrap"/>
        </Border>

        <!-- Appointments -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="No appointments for this day."
                           FontSize="20"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Try Previous/Next or Refresh."
                           Foreground="#9CA3AF"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- List -->
            <ListView ItemsSource="{Binding Appointments}" SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,12"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F3F4F6"
                                CornerRadius="22"
                                Padding="20"
                                BorderThickness="1"
                                BorderBrush="#E5E7EB">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="{Binding Type}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"/>
                                    <TextBlock Text="{Binding Location}"
                                               FontSize="15"
                                               Foreground="#6B7280"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="#2563EB"
                                        CornerRadius="14"
                                        Padding="16,8"
                                        VerticalAlignment="Center"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold"/>
                                </Border>

                                <Button Grid.Column="2"
                                        Content="Details"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="#111827"
                                        Background="Transparent"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        Padding="12,8"
                                        Click="DetailsButton_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Loading overlay -->
            <Grid Background="#66000000"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                    <ProgressRing IsActive="True" Width="56" Height="56"/>
                    <TextBlock Text="Loading appointments..."
                               Foreground="White"
                               FontSize="18"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>