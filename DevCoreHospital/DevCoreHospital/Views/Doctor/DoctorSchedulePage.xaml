<Page
    x:Class="DevCoreHospital.Views.Doctor.DoctorSchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:DevCoreHospital.ViewModels.Doctor"
    xmlns:conv="using:DevCoreHospital.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibility" />
    </Page.Resources>

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Doctor Schedule" FontSize="28" FontWeight="SemiBold" Margin="0,0,20,0"/>
            <Button Content="Previous" Command="{Binding PreviousDayCommand}" />
            <Button Content="Today" Command="{Binding TodayCommand}" />
            <Button Content="Next" Command="{Binding NextDayCommand}" />
            <TextBlock Text="{Binding SelectedDateText}" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="20,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Border Background="#FFF5F5" BorderBrush="#FCA5A5" BorderThickness="1"
                    Padding="12" CornerRadius="8"
                    Visibility="{Binding IsAccessDenied, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Access denied. This page is available only for Doctor users."
                           Foreground="#991B1B"/>
            </Border>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock Text="Loading schedule..." HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>

            <Border Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                    Padding="12" CornerRadius="8" VerticalAlignment="Top"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#92400E"/>
            </Border>

            <TextBlock Text="No appointments for this day."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"/>

            <ListView ItemsSource="{Binding Appointments}" Margin="0,10,0,0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:AppointmentItemViewModel">
                        <Border Margin="0,6,0,6" Padding="12" CornerRadius="10"
                                BorderBrush="#E5E7EB" BorderThickness="1" Background="White">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{x:Bind TimeRange}" FontWeight="SemiBold"/>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="{x:Bind Type}" />
                                    <TextBlock Text="{x:Bind Location}" Foreground="#6B7280"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                    <Border Background="{x:Bind StatusBrush}" CornerRadius="10" Padding="8,3">
                                        <TextBlock Text="{x:Bind Status}" Foreground="White"/>
                                    </Border>
                                    <Button Content="Details"
                                            Click="DetailsButton_Click"
                                            Tag="{x:Bind Id}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>