<Page
    x:Class="DevCoreHospital.Views.Doctor.AppointmentDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#FF0B120D"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF0F1711"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FFB7C2BA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF166534"/>
    </Page.Resources>

    <ScrollViewer Background="{StaticResource BgBrush}">
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Appointment Details"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="40"
                       FontWeight="SemiBold"/>

            <Border Grid.Row="1"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding AppointmentIdLine}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding PatientIdLine}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="18"/>

                    <TextBlock Text="{Binding DoctorIdLine}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="18"/>

                    <TextBlock Text="{Binding TimeLine}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="18"/>

                    <TextBlock Text="{Binding StatusLine}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="18"/>
                </StackPanel>
            </Border>

            <Button Grid.Row="2"
                    Content="Back"
                    Width="120"
                    HorizontalAlignment="Left"
                    Click="Back_Click"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{StaticResource AccentBrush}"/>
        </Grid>
    </ScrollViewer>
</Page>