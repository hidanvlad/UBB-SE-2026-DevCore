<Page
    x:Class="DevCoreHospital.Views.RoleDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="280"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- Left menu -->
		<Border Grid.Column="0" Background="#0F172A">
			<Grid Padding="16" RowSpacing="16">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<StackPanel>
					<TextBlock Text="DevCore Hospital"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>
					<TextBlock x:Name="RoleText"
                               Foreground="#93C5FD"
                               Margin="0,6,0,0"/>
				</StackPanel>

				<ListView x:Name="MenuList"
                          Grid.Row="1"
                          SelectionChanged="MenuList_SelectionChanged"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectionMode="Single">
					<ListView.ItemTemplate>
						<DataTemplate>
							<Border CornerRadius="10" Padding="12" Margin="0,0,0,8" Background="#111827">
								<TextBlock Text="{Binding Title}" Foreground="White" FontSize="16"/>
							</Border>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>

				<Button Grid.Row="2"
                        Content="Change Role"
                        Click="ChangeRole_Click"/>
			</Grid>
		</Border>

		<!-- Right content -->
		<Grid Grid.Column="1" Background="#1F2937">
			<Frame x:Name="ContentFrame"/>
		</Grid>
	</Grid>
</Page>