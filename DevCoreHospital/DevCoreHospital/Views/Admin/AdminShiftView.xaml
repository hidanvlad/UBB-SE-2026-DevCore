<Page
    x:Class="DevCoreHospital.Views.Admin.AdminShiftView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DevCoreHospital.Models"
    mc:Ignorable="d">

    <Grid Padding="20" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="15" Margin="0,0,20,0">
            <TextBlock Text="Creare Tură Nouă" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,10"/>

            <ComboBox x:Name="LocationComboBox" 
                      Header="Locație / Departament" 
                      PlaceholderText="Selectează locația" 
                      HorizontalAlignment="Stretch"
                      SelectionChanged="LocationComboBox_SelectionChanged">
                <x:String>ER</x:String>
                <x:String>Cardiology</x:String>
                <x:String>Central Pharmacy</x:String>
                <x:String>Neurology</x:String>
            </ComboBox>

            <ComboBox x:Name="StaffComboBox" 
                      Header="Selectează Angajatul" 
                      PlaceholderText="Alege un angajat pentru tură"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{x:Bind ViewModel.AvailableStaff, Mode=OneWay}"
                      DisplayMemberPath="FirstName" />

            <TextBlock Text="Personal calificat găsit:" Margin="0,5,0,-10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <ListView ItemsSource="{x:Bind ViewModel.AvailableStaff, Mode=OneWay}"
                      MaxHeight="120" 
                      BorderThickness="1" 
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      CornerRadius="4"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:IStaff">
                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="5">
                            <SymbolIcon Symbol="ContactInfo" Foreground="{ThemeResource SystemFillColorBrandBrush}"/>
                            <TextBlock Text="{x:Bind FirstName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind LastName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <CalendarDatePicker x:Name="ShiftDatePicker" 
                                Header="Data Turei" 
                                HorizontalAlignment="Stretch"/>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TimePicker x:Name="StartTimePicker" Header="Ora Început" Grid.Column="0" HorizontalAlignment="Stretch"/>
                <TimePicker x:Name="EndTimePicker" Header="Ora Sfârșit" Grid.Column="1" HorizontalAlignment="Stretch"/>
            </Grid>

            <Button Content="Programează Tura" 
                    Click="CreateShift_Click" 
                    Style="{StaticResource AccentButtonStyle}" 
                    HorizontalAlignment="Stretch" Margin="0,10,0,0"/>

            <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" />
        </StackPanel>

        <Grid Grid.Column="1" Margin="20,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Management Ture (Dashboard)" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,20"/>

            <ListView Grid.Row="1" 
                      ItemsSource="{x:Bind ViewModel.Shifts, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Shift">
                        <Grid Padding="15" Margin="0,0,0,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="{x:Bind AppointedStaff.FirstName}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{x:Bind AppointedStaff.LastName}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{x:Bind Location}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{x:Bind StartTime}"/>
                                    <TextBlock Text="-"/>
                                    <TextBlock Text="{x:Bind EndTime}"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind Status}" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Button Content="Set Active" Click="SetActive_Click" Tag="{x:Bind Id}" />
                                <Button Content="Cancel" Click="CancelShift_Click" Tag="{x:Bind Id}" />
                                <Button Content="Auto-Reassign" Click="AutoReassign_Click" Tag="{x:Bind}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>