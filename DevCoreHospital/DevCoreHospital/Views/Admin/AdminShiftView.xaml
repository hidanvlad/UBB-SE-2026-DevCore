<Page
    x:Class="DevCoreHospital.Views.Admin.AdminShiftView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DevCoreHospital.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#FF0B120D"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF0F1711"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FFB7C2BA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF166534"/>
    </Page.Resources>

    <Grid Background="{StaticResource BgBrush}" Padding="24" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                CornerRadius="12" Padding="20" VerticalAlignment="Top">

            <StackPanel Spacing="15">
                <TextBlock Text="Creare Tură Nouă" Foreground="{StaticResource TextBrush}" 
                           FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <ComboBox x:Name="LocationComboBox" 
                          Header="Locație / Departament" 
                          PlaceholderText="Selectează locația" 
                          HorizontalAlignment="Stretch"
                          Foreground="{StaticResource TextBrush}"
                          SelectionChanged="LocationComboBox_SelectionChanged">
                    <x:String>ER</x:String>
                    <x:String>Cardiology</x:String>
                    <x:String>Central Pharmacy</x:String>
                    <x:String>Surgery</x:String>
                    <x:String>Neurology</x:String>
                </ComboBox>

                <ComboBox x:Name="StaffComboBox" 
                          Header="Selectează Angajatul" 
                          PlaceholderText="Alege un angajat pentru tură"
                          HorizontalAlignment="Stretch"
                          Foreground="{StaticResource TextBrush}"
                          ItemsSource="{x:Bind ViewModel.AvailableStaff, Mode=OneWay}"
                          DisplayMemberPath="FirstName" />

                <TextBlock Text="Personal calificat găsit:" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,5,0,-10"/>
                <ListView ItemsSource="{x:Bind ViewModel.AvailableStaff, Mode=OneWay}"
                          MaxHeight="120" BorderThickness="1" BorderBrush="#2E3B32"
                          CornerRadius="8" Background="#1A241C" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:IStaff">
                            <StackPanel Orientation="Horizontal" Spacing="10" Padding="5">
                                <SymbolIcon Symbol="ContactInfo" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="{x:Bind FirstName}" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind LastName}" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <CalendarDatePicker x:Name="ShiftDatePicker" 
                                    Header="Data Turei" 
                                    Foreground="{StaticResource TextBrush}"
                                    HorizontalAlignment="Stretch"/>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TimePicker x:Name="StartTimePicker" Header="Ora Început" Grid.Column="0" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Stretch"/>
                    <TimePicker x:Name="EndTimePicker" Header="Ora Sfârșit" Grid.Column="1" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Stretch"/>
                </Grid>

                <Button Content="Programează Tura" 
                        Click="CreateShift_Click" 
                        Background="{StaticResource AccentBrush}" Foreground="White" 
                        HorizontalAlignment="Stretch" Padding="10" Margin="0,10,0,0"/>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource CardBrush}"
              BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
              CornerRadius="12" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Management Ture (Dashboard)" Foreground="{StaticResource TextBrush}" 
                       FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>

            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Shifts, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Shift">
                        <Grid Padding="15" Margin="0,0,0,10" Background="#1A241C" CornerRadius="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{x:Bind AppointedStaff.FirstName}" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="{x:Bind AppointedStaff.LastName}" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind Location}" Foreground="{StaticResource MutedBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{x:Bind StartTime}" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="-" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="{x:Bind EndTime}" Foreground="{StaticResource TextBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind Status}" Foreground="#4CAF50" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Button Content="Set Active" Click="SetActive_Click" Tag="{x:Bind Id}" Background="#2E7D32" Foreground="White"/>
                                <Button Content="Cancel" Click="CancelShift_Click" Tag="{x:Bind Id}" Background="#C62828" Foreground="White"/>
                                <Button Content="Auto-Reassign" Click="AutoReassign_Click" Tag="{x:Bind}" Background="#0277BD" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>