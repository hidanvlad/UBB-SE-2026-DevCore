<Page
    x:Class="DevCoreHospital.Views.AppointmentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DevCoreHospital.Models">

    <Page.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#FF0B120D"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF0F1711"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FFB7C2BA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF166534"/>
    </Page.Resources>

    <Grid Padding="24" ColumnSpacing="20" Background="{StaticResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource CardBrush}" 
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" 
                CornerRadius="12" Padding="20" VerticalAlignment="Top">
            <StackPanel Spacing="15">
                <TextBlock Text="New Appointment" Foreground="{StaticResource TextBrush}" 
                           FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <ComboBox x:Name="DoctorComboBox" Header="Select Doctor" 
                          PlaceholderText="Choose a doctor" HorizontalAlignment="Stretch"
                          Foreground="{StaticResource TextBrush}"/>

                <TextBox x:Name="PatientIdTextBox" Header="Patient ID (External Ref)" 
                         PlaceholderText="e.g. PAT-98765" Foreground="{StaticResource TextBrush}"/>

                <CalendarDatePicker x:Name="AppointmentDatePicker" Header="Date" 
                                    HorizontalAlignment="Stretch" Foreground="{StaticResource TextBrush}"/>

                <TimePicker x:Name="AppointmentTimePicker" Header="Time" 
                            HorizontalAlignment="Stretch" Foreground="{StaticResource TextBrush}"/>

                <Button Content="Book Appointment" Click="BookAppointment_Click"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        HorizontalAlignment="Stretch" Padding="10" Margin="0,10,0,0"/>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource CardBrush}" 
              BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" 
              CornerRadius="12" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,20">
                <TextBlock Text="Doctor's Schedule" Foreground="{StaticResource TextBrush}" 
                           FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>

                <ComboBox x:Name="FilterDoctorComboBox" PlaceholderText="Filter by Doctor" 
                          Width="250" SelectionChanged="FilterDoctorComboBox_SelectionChanged"
                          Foreground="{StaticResource TextBrush}"/>
            </StackPanel>

            <ListView Grid.Row="1" x:Name="AppointmentsListView" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="15" Margin="0,0,0,10" Background="#1A241C" CornerRadius="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{Binding PatientExternalId}" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{Binding DateString}" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Button Content="Finish" Click="FinishAppointment_Click" Tag="{Binding}"
                                        Background="#2E7D32" Foreground="White"/>
                                <Button Content="Cancel" Click="CancelAppointment_Click" Tag="{Binding}"
                                        Background="#C62828" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>