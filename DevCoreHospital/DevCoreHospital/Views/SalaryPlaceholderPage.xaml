<Page
    x:Class="DevCoreHospital.Views.SalaryPlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32">
        <StackPanel Spacing="20" MaxWidth="450" HorizontalAlignment="Left" VerticalAlignment="Top">

            <TextBlock Text="Compute Staff Salary" FontSize="32" FontWeight="SemiBold"/>
            <TextBlock Text="Calculate monthly earnings based on scheduled shifts and role-specific bonuses." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>

            <ComboBox Header="Select Staff Member" 
                      ItemsSource="{x:Bind ViewModel.StaffList}" 
                      SelectedItem="{x:Bind ViewModel.SelectedStaff, Mode=TwoWay}"
                      DisplayMemberPath="LastName"
                      HorizontalAlignment="Stretch"
                      PlaceholderText="Choose an employee..."/>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <NumberBox Header="Month (1-12)" Value="{x:Bind ViewModel.SelectedMonth, Mode=TwoWay}" Minimum="1" Maximum="12" Grid.Column="0"/>
                <NumberBox Header="Year" Value="{x:Bind ViewModel.SelectedYear, Mode=TwoWay}" Minimum="2000" Grid.Column="1"/>
            </Grid>

            <Button Content="Calculate Salary" 
                    Command="{x:Bind ViewModel.ComputeSalaryCommand}" 
                    Style="{StaticResource AccentButtonStyle}" 
                    HorizontalAlignment="Stretch"
                    Height="40"/>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                          Width="40" Height="40" 
                          HorizontalAlignment="Center" />

            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" 
                       Foreground="#EF4444" 
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{x:Bind ViewModel.SalaryResult, Mode=OneWay}" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#22C55E"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>