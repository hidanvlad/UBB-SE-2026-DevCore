<Page
    x:Class="DevCoreHospital.Views.IncomingSwapRequestsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Page.Resources>
		<SolidColorBrush x:Key="BgBrush" Color="#FF0B120D"/>
		<SolidColorBrush x:Key="CardBrush" Color="#FF0F1711"/>
		<SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
		<SolidColorBrush x:Key="MutedBrush" Color="#FFB7C2BA"/>
		<SolidColorBrush x:Key="AccentBrush" Color="#FF166534"/>
	</Page.Resources>

	<Grid Background="{StaticResource BgBrush}" Padding="24">
		<Border Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
			<StackPanel Spacing="10">
				<TextBlock Text="Incoming Swap Requests"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="24"
                           FontWeight="SemiBold"/>

				<TextBlock Text="Select doctor (test mode)"
                           Foreground="{StaticResource MutedBrush}"/>

				<ComboBox ItemsSource="{Binding Doctors}"
                          SelectedItem="{Binding SelectedDoctor, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          PlaceholderText="Select doctor" />

				<ListView ItemsSource="{Binding Requests}"
                          SelectedItem="{Binding SelectedRequest, Mode=TwoWay}"
                          MinHeight="260">
					<ListView.ItemTemplate>
						<DataTemplate>
							<Border BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,0,8">
								<TextBlock Text="{Binding DisplayText}"
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap"/>
							</Border>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>

				<StackPanel Orientation="Horizontal" Spacing="8">
					<Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"/>

					<Button Content="Accept"
                            Command="{Binding AcceptCommand}"
                            Background="#FF0E9F6E"
                            Foreground="White"/>

					<Button Content="Reject"
                            Command="{Binding RejectCommand}"
                            Background="#FFB91C1C"
                            Foreground="White"/>
				</StackPanel>

				<InfoBar IsOpen="True"
                         IsClosable="False"
                         Severity="Informational"
                         Message="{Binding StatusMessage}" />
			</StackPanel>
		</Border>
	</Grid>
</Page>