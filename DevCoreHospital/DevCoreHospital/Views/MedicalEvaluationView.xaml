<Page
    x:Class="DevCoreHospital.Views.MedicalEvaluationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DevCoreHospital.Models"
    xmlns:converters="using:DevCoreHospital.Converters" 
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,30,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="15" Padding="0,0,15,20">
                    <TextBlock Text="1. MEDICAL EVALUATIONS" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBox Header="Patient ID" 
                             Text="{x:Bind ViewModel.PatientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             PlaceholderText="Searching for active patient..."
                             IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"/>

                    <TextBox Header="Symptoms" 
                             Text="{x:Bind ViewModel.Symptoms, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                             PlaceholderText="Enter symptoms..." 
                             AcceptsReturn="True" MinHeight="100"
                             MaxLength="500"/>

                    <TextBox Header="Meds List" 
                             Text="{x:Bind ViewModel.MedsList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Enter medications..." AcceptsReturn="True" MinHeight="60"
                             IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                             MaxLength="200"
                             ToolTipService.ToolTip="Include name, dosage, and quantity (e.g., Paracetamol 500mg, 20 tabs)."/>

                    <StackPanel Visibility="{x:Bind ViewModel.ConflictVisibility, Mode=OneWay}" Spacing="10">
                        <InfoBar Severity="Error"
                                 Title="Risk Conflict Detected"
                                 Message="{x:Bind ViewModel.ConflictWarning, Mode=OneWay}"
                                 IsOpen="True" IsClosable="False" />

                        <InfoBar Severity="Warning" 
                                 Title="History Alert" 
                                 Message="Historical adverse reactions found. Clinical justification required." 
                                 IsOpen="True" IsClosable="False" />

                        <CheckBox Content="I assume clinical risk for this prescription" 
                                  IsChecked="{x:Bind ViewModel.IsRiskAssumed, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                                  FontWeight="Bold" Foreground="Yellow"/>
                    </StackPanel>

                    <TextBox Header="Doctor Notes" 
                             Text="{x:Bind ViewModel.DoctorNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Write justification here..." 
                             AcceptsReturn="True" MinHeight="100"
                             IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                             Background="{x:Bind ViewModel.NotesBackground, Mode=OneWay}"
                             MaxLength="1000"
                             ToolTipService.ToolTip="Notes for possible issues, clinical observations, or follow-up requirements."/>

                    <TextBlock Text="{x:Bind ViewModel.ValidationError, Mode=OneWay}" 
                               Foreground="OrangeRed" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               TextWrapping="WrapWholeWords"
                               Margin="0,5"/>

                    <Button Content="Save Diagnosis" 
                            Command="{x:Bind ViewModel.SaveDiagnosisCommand}" 
                            HorizontalAlignment="Stretch" Height="45"
                            Style="{StaticResource AccentButtonStyle}"/>

                    <Button Content="Delete Diagnosis" 
                            Click="DeleteButton_Click"
                            IsEnabled="{x:Bind ViewModel.IsEditing, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Stretch" Height="45"
                            Background="DarkRed" Foreground="White"/>

                    <Button Content="Cancel Edit" 
                            Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            Click="{x:Bind ViewModel.ResetForm}"
                            HorizontalAlignment="Stretch" Margin="0,5"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Visibility="{x:Bind ViewModel.LockoutVisibility, Mode=OneWay}" 
                  Background="#CC000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Canvas.ZIndex="10">
                <Border Background="#A80303" VerticalAlignment="Center" Padding="20,40" CornerRadius="8" Margin="10">
                    <StackPanel Spacing="5" HorizontalAlignment="Center">
                        <TextBlock Text="CLINICAL LOCKOUT." FontSize="32" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Maximum duty hours (12h) exceeded." FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Column="1" Spacing="10">
            <TextBlock Text="Medical Records" FontSize="22" FontWeight="Bold"/>

            <TextBox PlaceholderText="Search by Patient ID..."
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Header="Filter History"
                     Margin="0,0,0,10"/>

            <Grid VerticalAlignment="Stretch">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="60" Height="60"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"
                              Canvas.ZIndex="2"/>

                <StackPanel Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center" 
                            Spacing="12"
                            Margin="0,100,0,0">
                    <FontIcon Glyph="&#xE8A5;" FontSize="56" Foreground="Gray" Opacity="0.4"/>
                    <TextBlock Text="No matches found." 
                               FontSize="16" 
                               Foreground="Gray" 
                               FontStyle="Italic"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <ListView ItemsSource="{x:Bind ViewModel.PastEvaluations, Mode=OneWay}" 
                          SelectedItem="{x:Bind ViewModel.SelectedEvaluation, Mode=TwoWay}"
                          Background="{ThemeResource LayerFillColorDefaultBrush}" 
                          CornerRadius="8" 
                          Padding="10" 
                          MinHeight="400">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:MedicalEvaluation">
                            <Grid Padding="10" BorderBrush="Gray" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <TextBlock Text="{x:Bind FormattedDate}" FontWeight="Bold"/>
                                    <TextBlock Text="{x:Bind FormattedTime}" Foreground="Gray" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{x:Bind Symptoms}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                    <TextBlock Text="Status: Completed" FontSize="11" Foreground="Green"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </StackPanel>
    </Grid>
</Page>